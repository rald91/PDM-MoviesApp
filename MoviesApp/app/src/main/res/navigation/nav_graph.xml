<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.moviesapp.ui.fragments.LoginFragment"
        android:label="Login" />

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.example.moviesapp.ui.fragments.MovieListFragment"
        android:label="Movie List">
        <action
            android:id="@+id/action_to_movieDetails"
            app:destination="@id/movieDetailsFragment">
            <argument
                android:name="movieId"
                app:argType="integer" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/addMovieFragment"
        android:name="com.example.moviesapp.ui.fragments.AddMovieFragment"
        android:label="Add Movie" />

    <fragment
        android:id="@+id/addPersonFragment"
        android:name="com.example.moviesapp.ui.fragments.AddPersonFragment"
        android:label="Add Person" />

    <fragment
        android:id="@+id/movieDetailsFragment"
        android:name="com.example.moviesapp.ui.fragments.MovieDetailsFragment"
        android:label="Movie Details">
        <argument
            android:name="movieId"
            app:argType="integer" />
    </fragment>

</navigation>
